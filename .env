POSTGRES_CONTAINER_PORT=5432
POSTGRES_HOST_PORT=5433
NGINX_HOST_PORT=13000
MCAP_LOGS_SUBDIR=mcap_logs

# App mode
DEBUG=True
# Change in production and keep secret.
SECRET_KEY=django-insecure-change-me

# Preferred Django database setting (django-environ)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/mcap_query_db

# Legacy/fallback DB vars (still supported)
POSTGRES_DB=mcap_query_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Optional override: absolute or MEDIA_ROOT-relative path used for uploaded MCAP files.
# Example absolute: /app/media/mcap_uploads
# Example relative: mcap_uploads
# MCAP_LOGS_DIR=mcap_logs

# Application host/domain settings
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:13000,http://127.0.0.1:13000
NEXT_PUBLIC_API_BASE_URL=/api
